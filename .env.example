# Local Intelligence — environment configuration
# Copy to .env and modify as needed:  cp .env.example .env
# Or run: make setup (interactive wizard that detects your hardware)

# ── Profile ─────────────────────────────────────────────────────────
# Which LLM services to start. Pick ONE:
#   cpu      Falcon3 10B on CPU (default, 12+ GB RAM)
#   gpu      Qwen 3.5 9B on NVIDIA GPU (8+ GB VRAM)
#   dual     Falcon3 triage (CPU) + Qwen synthesis (GPU) — best quality
#   minimal  Falcon3 3B on CPU (<8 GB RAM)
COMPOSE_PROFILES=cpu

# ── Pipeline mode ───────────────────────────────────────────────────
# How the orchestrator routes queries to LLM(s):
#   single   One LLM handles everything (cpu, gpu, minimal profiles)
#   dual     Falcon3 triages/filters, Qwen synthesizes (dual profile)
PIPELINE_MODE=single

# ── Data directory ──────────────────────────────────────────────────
# Where ZIM files, vectors, and documents live.
KNOWLEDGE_DIR=./data/knowledge

# ── Falcon3 (CPU) ──────────────────────────────────────────────────
FALCON_CTX_SIZE=32768     # Context window in tokens
                          #   32768 = ~7 GB RAM  (12+ GB machines)
                          #   16384 = ~4.5 GB RAM
                          #    8192 = ~3.3 GB RAM (minimal profile)
FALCON_MEM_LIMIT=12g      # Docker memory limit for Falcon3 container
THREADS=0                  # 0 = auto-detect CPU count

# ── Qwen 3.5 (GPU) ─────────────────────────────────────────────────
QWEN_CTX_SIZE=8192        # Context window (GPU VRAM budget)
                          #   8192  = ~6.5 GB VRAM (safe for 10 GB cards)
                          #   16384 = ~8 GB VRAM
                          #   32768 = ~11 GB VRAM (needs 12+ GB card)
QWEN_GPU_LAYERS=99        # 99 = offload all layers to GPU

# ── LLM URLs ───────────────────────────────────────────────────────
# These are set automatically based on profile. Only override if you
# run LLM servers on a different host or port.
#
# Single-model profiles (cpu, gpu, minimal):
#   LLM_URL is the only URL used.
#
# Dual profile:
#   TRIAGE_LLM_URL  → Falcon3 (fast classification/filtering)
#   SYNTH_LLM_URL   → Qwen (reasoning/synthesis)
#   LLM_URL is ignored when both TRIAGE and SYNTH are set.

# cpu / minimal:
LLM_URL=http://falcon3:8080/v1/chat/completions

# gpu (uncomment to use):
# LLM_URL=http://qwen:8082/v1/chat/completions

# dual (uncomment to use):
# TRIAGE_LLM_URL=http://falcon3:8080/v1/chat/completions
# SYNTH_LLM_URL=http://qwen:8082/v1/chat/completions

# ── Ports ───────────────────────────────────────────────────────────
LLM_PORT=8080              # Falcon3 API
SYNTH_PORT=8082            # Qwen API
ORCHESTRATOR_PORT=8081     # Orchestrator (main entry point)
KIWIX_PORT=8888            # Kiwix knowledge server
WEBUI_PORT=3000            # Open WebUI

# ── RAG ─────────────────────────────────────────────────────────────
RAG_TOP_K=5                # Number of chunks to retrieve per query

# ── Advanced: custom model builds ──────────────────────────────────
# Falcon3 — smaller models for low-RAM machines:
#   docker compose build --build-arg MODEL_REPO=tiiuae/Falcon3-3B-Instruct-1.58bit falcon3
#   docker compose build --build-arg MODEL_REPO=tiiuae/Falcon3-1B-Instruct-1.58bit falcon3
#
# Qwen — different quantizations:
#   docker compose build --build-arg MODEL_FILE=Qwen3.5-9B-Q5_K_M.gguf qwen   # higher quality
#   docker compose build --build-arg MODEL_FILE=Qwen3.5-9B-Q2_K.gguf qwen     # lower VRAM
