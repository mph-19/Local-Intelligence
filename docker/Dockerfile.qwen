# Qwen 3.5 9B — GPU inference server (CUDA + llama.cpp)
# Multi-stage build: compile llama.cpp with CUDA in a fat image, run in a slim one.
#
# Build args:
#   MODEL_REPO    HuggingFace repo (default: unsloth/Qwen3.5-9B-GGUF)
#   MODEL_FILE    GGUF filename  (default: Qwen3.5-9B-Q4_K_M.gguf)
#
# Higher quality (needs more VRAM):
#   docker compose build --build-arg MODEL_FILE=Qwen3.5-9B-Q5_K_M.gguf qwen
#
# Lower VRAM (~3.5 GB):
#   docker compose build --build-arg MODEL_FILE=Qwen3.5-9B-Q2_K.gguf qwen

# ── Stage 1: Build llama.cpp with CUDA ─────────────────────────────
FROM nvidia/cuda:13.2.1-devel-ubuntu24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake \
    git \
    python3 \
    python3-pip \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

RUN ln -s /usr/local/cuda/lib64/stubs/libcuda.so /usr/local/cuda/lib64/stubs/libcuda.so.1

# Pin to known-good commit to prevent upstream breaking changes.
# To update: test a new commit locally, then replace the hash here.
ARG LLAMACPP_COMMIT=9f102a1407ed
RUN git clone https://github.com/ggerganov/llama.cpp.git . && \
    git checkout ${LLAMACPP_COMMIT} && \
    cmake -B build \
        -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES="86" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_EXE_LINKER_FLAGS="-Wl,-rpath-link,/usr/local/cuda/lib64/stubs" \
        -DCMAKE_SHARED_LINKER_FLAGS="-Wl,-rpath-link,/usr/local/cuda/lib64/stubs" && \
    cmake --build build --target llama-server -j"$(nproc)" && \
    mkdir -p /output/libs && \
    cp build/bin/llama-server /output/ && \
    find build -name "*.so*" -exec cp {} /output/libs/ \; 2>/dev/null; true && \
    rm -rf /build/.git /build/build /build/src /build/ggml

# ── Stage 2: Download model ────────────────────────────────────────
FROM python:3.14-slim AS downloader

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install huggingface-hub~=1.7.0

ARG MODEL_REPO=unsloth/Qwen3.5-9B-GGUF
ARG MODEL_FILE=Qwen3.5-9B-Q4_K_M.gguf

RUN python3 -c "from huggingface_hub import hf_hub_download; \
    hf_hub_download('${MODEL_REPO}', '${MODEL_FILE}', local_dir='/models')"

# ── Stage 3: Runtime ───────────────────────────────────────────────
FROM nvidia/cuda:13.2.1-runtime-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy llama-server binary and its shared libs
COPY --from=builder /output/llama-server /usr/local/bin/llama-server
COPY --from=builder /output/libs/ /usr/local/lib/
RUN ldconfig 2>/dev/null; true

# Copy model
COPY --from=downloader /models/ /models/

# Propagate model filename from build arg to runtime env.
# This avoids shell command substitution ($(cat ...)) in the ENTRYPOINT.
ARG MODEL_FILE=Qwen3.5-9B-Q4_K_M.gguf
ENV MODEL_PATH=/models/${MODEL_FILE}

# Non-root user — llama-server needs no write access.
# GID/UID 1000 may already exist in the NVIDIA base image; skip creation if so.
RUN if ! getent group 1000 >/dev/null; then groupadd --gid 1000 llmuser; fi && \
    if ! id -u 1000 >/dev/null 2>&1; then useradd --uid 1000 --gid 1000 --no-create-home llmuser; fi

EXPOSE 8082

ENV CTX_SIZE=8192
ENV PORT=8082
ENV GPU_LAYERS=99

USER 1000
ENTRYPOINT ["sh", "-c", \
    "exec llama-server \
        --model \"${MODEL_PATH}\" \
        --host 0.0.0.0 \
        --port ${PORT} \
        --n-gpu-layers ${GPU_LAYERS} \
        --ctx-size ${CTX_SIZE}"]
