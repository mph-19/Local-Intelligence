# Orchestrator + Ingestion worker — unified multi-target Dockerfile
# Both services share the same Python dependencies and nomic embedding model.
#
# Targets:
#   orchestrator  — long-running RAG proxy (default)
#   ingest        — one-shot document indexer
#
# Build:
#   docker compose build orchestrator   # builds 'orchestrator' target
#   docker compose build ingest         # builds 'ingest' target (same base, different CMD)

# ── Base: shared deps + pre-downloaded embedding model ────────────
FROM python:3.12-slim AS base

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY docker/requirements.orchestrator.txt requirements.txt
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# Non-root user for runtime security + consistent volume ownership.
# GID/UID 1000 may already exist in the base image; skip creation if so.
# /home/appuser is always created explicitly for HF_HOME.
RUN if ! getent group 1000 >/dev/null; then groupadd --gid 1000 appuser; fi && \
    if ! id -u 1000 >/dev/null 2>&1; then useradd --uid 1000 --gid 1000 --create-home appuser; fi && \
    mkdir -p /home/appuser /knowledge/vectors/qdrant && \
    chown -R 1000:1000 /home/appuser /knowledge /app

# Pre-download nomic embedding model into the image (~270 MB)
# This avoids a slow first-request delay at runtime.
# Revision is pinned to an audited commit — update deliberately, not automatically.
ARG EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
ARG EMBED_REVISION=e5cf08aadaa33385f5990def41f7a23405aec398
ENV HF_HOME=/home/appuser/.cache/huggingface
RUN python3 -c "from sentence_transformers import SentenceTransformer; \
    SentenceTransformer('${EMBED_MODEL}', trust_remote_code=True, revision='${EMBED_REVISION}')" && \
    chown -R 1000:1000 /home/appuser/.cache

# Copy all service + script code
COPY --chown=1000:1000 services/rag.py /app/rag.py
COPY --chown=1000:1000 services/orchestrator.py /app/orchestrator.py
COPY --chown=1000:1000 scripts/ingest_docs.py /app/ingest_docs.py
COPY --chown=1000:1000 scripts/ingest_kiwix.py /app/ingest_kiwix.py

# ── Orchestrator target ──────────────────────────────────────────
FROM base AS orchestrator

EXPOSE 8081

ENV LLM_URL=http://falcon3:8080/v1/chat/completions
ENV KIWIX_URL=http://kiwix:8888
ENV ORCHESTRATOR_PORT=8081
ENV QDRANT_PATH=/knowledge/vectors/qdrant

USER 1000
CMD ["python3", "orchestrator.py"]

# ── Ingest target ────────────────────────────────────────────────
FROM base AS ingest

ENV QDRANT_PATH=/knowledge/vectors/qdrant
ENV KIWIX_URL=http://kiwix:8888

USER 1000
CMD ["python3", "ingest_docs.py", "/knowledge/docs/custom", "custom_docs"]
